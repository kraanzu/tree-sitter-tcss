    "widget_selector": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_-]*"
    },
    "combinator": {
      "type": "STRING",
      "value": ">"
    },
    "rule_set": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "selectors"
        },
        {
          "type": "SYMBOL",
          "name": "block"
        }
      ]
    },
    "block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "declaration"
              },
              {
                "type": "SYMBOL",
                "name": "rule_set"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
